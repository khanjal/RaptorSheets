root = true

# Activates the same SonarCloud "Sonar way" C# rule set (Directory.Build.props references
# SonarAnalyzer.CSharp) locally, at build time and in the IDE - so findings like naming
# conventions and Cognitive Complexity show up immediately instead of only after CI. Generated
# from the khanjal_RaptorSheets SonarCloud project's active quality profile
# (api/qualityprofiles/search, api/rules/search) - re-run that query and regenerate if the cloud
# profile changes. All rules are set to "warning" (never "error") so this never breaks the build;
# it surfaces findings for triage, matching how the SonarCloud PR gate already behaves for new code.

[*.cs]

dotnet_diagnostic.S7788.severity = warning
dotnet_diagnostic.S7789.severity = warning
dotnet_diagnostic.S8134.severity = warning
dotnet_diagnostic.S8464.severity = warning
